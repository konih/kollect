{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "kollect Helm values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": {
          "type": "boolean"
        }
      }
    },
    "tenantMode": {
      "type": "boolean",
      "description": "When true, render namespaced Role/RoleBinding instead of ClusterRole/ClusterRoleBinding."
    },
    "mode": {
      "type": "string",
      "enum": ["single", "hub", "spoke"]
    },
    "hub": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "platformNamespace": {
          "type": "string"
        },
        "exportNamespace": {
          "type": "string"
        },
        "sinkRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "remoteClusters": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ingestPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "ingestAuthMode": {
          "type": "string",
          "enum": ["kubernetes", "disabled"]
        }
      }
    },
    "transport": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["inprocess", "redis", "nats", "kafka"],
          "default": "inprocess",
          "description": "Hub/spoke transport backend (ADR-0502). Only inprocess is the production default."
        }
      }
    },
    "watchNamespaces": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sinkDefaults": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "connectionTest": {
          "type": "boolean"
        }
      }
    },
    "featureGates": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "inventoryHttp": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false,
              "description": "Expose GET /inventory for debug and small installs only (ADR-0703)."
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "default": 8082
            },
            "authMode": {
              "type": "string",
              "enum": ["kubernetes", "disabled"],
              "default": "kubernetes"
            }
          }
        }
      }
    },
    "webhooks": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Expose controller /metrics endpoint."
        },
        "bindAddress": {
          "type": "string",
          "minLength": 1
        },
        "secure": {
          "type": "boolean",
          "description": "When true, metrics are served over HTTPS with Kubernetes API authn/authz."
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create a ServiceMonitor CR (requires Prometheus Operator CRDs)."
            },
            "interval": {
              "type": "string"
            },
            "scrapeTimeout": {
              "type": "string"
            },
            "labels": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "prometheusRule": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create default PrometheusRule alerts (requires Prometheus Operator CRDs)."
            },
            "labels": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "additionalRules": {
              "type": "array",
              "description": "Extra alert rules appended to the kollect.rules group."
            }
          }
        }
      }
    }
  }
}
